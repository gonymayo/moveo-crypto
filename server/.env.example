# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
# Local:   postgresql://postgres:password@localhost:5432/moveo_crypto
# Render:  postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/moveo_crypto"

# ── Auth ──────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_me_to_a_long_random_string"
JWT_EXPIRES_IN="7d"

# ── External APIs ─────────────────────────────────────────
# CoinGecko — free tier, no key required for public endpoints
# https://www.coingecko.com/en/api/documentation
COINGECKO_BASE_URL="https://api.coingecko.com/api/v3"

# CryptoPanic — register at https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY="your_cryptopanic_api_key_here"
CRYPTOPANIC_BASE_URL="https://cryptopanic.com/api/v1"

# OpenRouter — register at https://openrouter.ai/ (free credits on signup)
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="mistralai/mistral-7b-instruct:free"

# Reddit — no auth needed for JSON API
REDDIT_BASE_URL="https://www.reddit.com"

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,https://your-app.vercel.app"
